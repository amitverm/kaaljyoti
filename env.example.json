{
  "SUPABASE_URL": "https://<PROJECT_REF>.supabase.co",
  "SUPABASE_ANON_KEY": "sb_publishable_...",
  "GOOGLE_WEB_CLIENT_ID": "<number>-<hash>.apps.googleusercontent.com",
  "GOOGLE_IOS_CLIENT_ID": "<number>-<hash>.apps.googleusercontent.com",
  "SENTRY_DSN": "https://<key>@<org>.ingest.sentry.io/<project>  (optional - empty/absent disables crash reporting)",
  "FIREBASE_MESSAGING_SENDER_ID": "<project-wide: plist GCM_SENDER_ID / json project_info.project_number>",
  "FIREBASE_PROJECT_ID": "<project-wide: plist PROJECT_ID / json project_info.project_id>",
  "FIREBASE_API_KEY_IOS": "<GoogleService-Info.plist -> API_KEY>  (all FIREBASE_* optional - empty disables push, bell still works)",
  "FIREBASE_APP_ID_IOS": "<GoogleService-Info.plist -> GOOGLE_APP_ID, looks like 1:123...:ios:abc...>",
  "FIREBASE_API_KEY_ANDROID": "<google-services.json -> client[].api_key[].current_key>",
  "FIREBASE_APP_ID_ANDROID": "<google-services.json -> client[].client_info.mobilesdk_app_id, looks like 1:123...:android:abc...>"
}
